                {
                  "type": "REPEAT1",
                  "content": {
                    "type": "SEQ",
                    "members": [
                      {
                        "type": "STRING",
                        "value": "%"
                      },
                      {
                        "type": "STRING",
                        "value": "\n"
                      }
                    ]
                  }
                },
                {
                  "type": "SYMBOL",
                  "name": "prolog_style_body"
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "prolog_style_body": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SEQ",
          "members": [
            {
              "type": "SYMBOL",
              "name": "prolog_style_description"
            },
            {
              "type": "REPEAT1",
              "content": {
                "type": "SEQ",
                "members": [
                  {
                    "type": "STRING",
                    "value": "%"
                  },
                  {
                    "type": "SYMBOL",
                    "name": "pl_tag"
                  }
                ]
              }
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "prolog_style_description"
        },
        {
          "type": "REPEAT1",
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "STRING",
                "value": "%"
              },
              {
                "type": "SYMBOL",
                "name": "pl_tag"
              }
            ]
          }
        }
      ]
    },
    "_prolog_style_description": {
      "type": "REPEAT1",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "%"
          },
          {
            "type": "PATTERN",
            "value": "([^@\\s].*)|(\\s+[^@].*)"
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "STRING",
                "value": "\n"
              },
              {
                "type": "STRING",
                "value": "\u0000"
              }
            ]
          }
        ]
      }
    },
    "prolog_style_description": {
      "type": "REPEAT1",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "PATTERN",
            "value": "%[\\r\\t\\f\\v ]*[^@\\s].*\\n"
          },
          {
            "type": "PATTERN",
            "value": "%\\s*\\n"
          }
        ]
      }
    },
    "pldoc_c_style": {
      "type": "SEQ",
      "members": [
        {
          "type": "TOKEN",
