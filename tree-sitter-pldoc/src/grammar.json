{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "pldoc",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "comment"
      }
    },
    "comment": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "normal_comment"
        },
        {
          "type": "SYMBOL",
          "name": "pldoc_comment"
        }
      ]
    },
    "normal_comment": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "normal_single_line_comment"
        }
      ]
    },
    "normal_single_line_comment": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "%"
        },
        {
          "type": "PATTERN",
          "value": ".*"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "STRING",
              "value": "\n"
            },
            {
              "type": "STRING",
              "value": "\u0000"
            }
          ]
        }
      ]
    },
    "normal_multiline_comment": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "/*"
          },
          {
            "type": "REPEAT",
            "content": {
              "type": "SEQ",
              "members": [
                {
                  "type": "PATTERN",
                  "value": "(([^*\\n]\\/)|([^*\\/\\n])|\\*|(\\*[^\\/\\n]))*"
                },
                {
                  "type": "PATTERN",
                  "value": "\\n?"
                }
              ]
            }
          },
          {
            "type": "STRING",
            "value": "*/"
          }
        ]
      }
    },
    "_template": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "functor_template"
        },
        {
          "type": "SYMBOL",
          "name": "directive_template"
        }
      ]
    },
    "operator_template": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SEQ",
          "members": [
            {
              "type": "SYMBOL",
              "name": "arg_spec"
            },
            {
              "type": "PATTERN",
              "value": "[^\\s]+"
            },
            {
              "type": "SYMBOL",
              "name": "arg_spec"
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "PATTERN",
              "value": "[^\\s]+"
            },
            {
              "type": "SYMBOL",
              "name": "arg_spec"
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "SYMBOL",
              "name": "arg_spec"
            },
            {
              "type": "PATTERN",
              "value": "[^\\s]+"
            }
          ]
        }
      ]
    },
    "functor_template": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_head"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "STRING",
                  "value": "is"
                },
                {
                  "type": "CHOICE",
                  "members": [
                    {
                      "type": "STRING",
                      "value": "det"
                    },
                    {
                      "type": "STRING",
                      "value": "semidet"
                    },
                    {
                      "type": "STRING",
                      "value": "failure"
                    },
                    {
                      "type": "STRING",
                      "value": "nondet"
                    },
                    {
                      "type": "STRING",
                      "value": "multi"
                    },
                    {
                      "type": "STRING",
                      "value": "undefined"
                    }
                  ]
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "directive_template": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": ":-"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "functor_template"
            },
            {
              "type": "SYMBOL",
              "name": "operator_template"
            }
          ]
        }
      ]
    },
    "_head": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "functor"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "STRING",
                  "value": "("
                },
                {
                  "type": "REPEAT",
                  "content": {
                    "type": "SEQ",
                    "members": [
                      {
                        "type": "SYMBOL",
                        "name": "arg_spec"
                      },
                      {
                        "type": "STRING",
                        "value": ","
                      }
                    ]
                  }
                },
                {
                  "type": "SYMBOL",
                  "name": "arg_spec"
                },
                {
                  "type": "STRING",
                  "value": ")"
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "arg_spec": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "CHOICE",
              "members": [
                {
                  "type": "STRING",
                  "value": "++"
                },
                {
                  "type": "STRING",
                  "value": "+"
                },
                {
                  "type": "STRING",
                  "value": "-"
                },
                {
                  "type": "STRING",
                  "value": "--"
                },
                {
                  "type": "STRING",
                  "value": "?"
                },
                {
                  "type": "STRING",
                  "value": ":"
                },
                {
                  "type": "STRING",
                  "value": "@"
                },
                {
                  "type": "STRING",
                  "value": "!"
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "arg_name"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "STRING",
                  "value": ":"
                },
                {
                  "type": "SYMBOL",
                  "name": "type"
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "functor": {
      "type": "PATTERN",
      "value": "[a-zA-Z0-9_$]+"
    },
    "type": {
      "type": "PATTERN",
      "value": "[^\\s]+"
    },
    "arg_name": {
      "type": "PATTERN",
      "value": "[a-zA-Z0-9_$]+"
    },
    "pldoc_comment": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "pldoc_prolog_style"
        },
        {
          "type": "SYMBOL",
          "name": "pldoc_c_style"
        }
      ]
    },
    "pldoc_prolog_directive": {
      "type": "SEQ",
      "members": [
        {
          "type": "TOKEN",
          "content": {
            "type": "PREC",
            "value": 1,
            "content": {
              "type": "SEQ",
              "members": [
                {
                  "type": "STRING",
                  "value": "%"
                },
                {
                  "type": "CHOICE",
                  "members": [
                    {
                      "type": "STRING",
                      "value": "! "
                    },
                    {
                      "type": "STRING",
                      "value": "% "
                    }
                  ]
                }
              ]
            }
          }
        },
        {
          "type": "SYMBOL",
          "name": "_template"
        }
      ]
    },
    "pldoc_prolog_style": {
      "type": "SEQ",
      "members": [
        {
          "type": "REPEAT1",
          "content": {
            "type": "SYMBOL",
            "name": "pldoc_prolog_directive"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
